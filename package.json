{
  "name": "velocity-operations",
  "version": "0.1.0",
  "description": "Work Order Management System",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "build": "vite build",
    "package": "npm run build && electron-builder",
    "rebuild": "HOME=~/.electron-gyp node_modules/.bin/node-gyp rebuild --target=29.4.6 --arch=arm64 --dist-url=https://electronjs.org/headers",
    "start": "electron ."
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "googleapis": "^140.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.hotlistco.velocity-operations",
    "productName": "Velocity Operations",
    "mac": {
      "category": "public.app-category.business"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      { "from": "server/db/schema.sql", "to": "schema.sql" }
    ]
  }
}
